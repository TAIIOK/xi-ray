#!/bin/sh /etc/rc.common

START=99
STOP=10

USE_PROCD=1

start_service() {
  STARTUP="$(ls /mnt/usb-*/xiaomi-vless/startup_xray_guest.sh 2>/dev/null | head -1)"
  [ -x "$STARTUP" ] || return 1
  procd_open_instance
  procd_set_param command /bin/sh
  procd_append_param command -c
  procd_append_param command "(${STARTUP}) >/dev/null 2>&1 &"
  procd_set_param respawn 3600 5 0
  procd_close_instance
}

stop_service() {
  killall xray 2>/dev/null || true
}
