#!/bin/sh /etc/rc.common

START=99
STOP=10

USE_PROCD=1

start_service() {
  [ -x /data/xiaomi-vless-boot.sh ] || return 1
  procd_open_instance
  procd_set_param command /bin/sh
  procd_append_param command -c
  procd_append_param command "/data/xiaomi-vless-boot.sh >/dev/null 2>&1 &"
  procd_close_instance
}
